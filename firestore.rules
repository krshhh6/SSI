rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: is the requesting user an admin?
    function isAdmin() {
      return request.auth != null &&
        request.auth.token.email == 'test01samwheels@gmail.com';
    }

    // ── bookings collection ──────────────────────────────────────
    match /bookings/{bookingId} {
      // Any signed-in user can create a booking
      allow create: if request.auth != null;

      // Users can read/update/delete their own bookings.
      // Admins can read/update/delete any booking.
      allow read, update, delete: if request.auth != null &&
        (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ── users collection ─────────────────────────────────────────
    match /users/{userId} {
      // Users can read and write their own document.
      // Admins can read any user document.
      allow read: if request.auth != null &&
        (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null &&
        request.auth.uid == userId;
    }

  }
}
